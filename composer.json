{
  "name": "comphp/cache-symfony-cache",
  "type": "library",
  "description": "Cache Driver for CommonPHP which utilizes the Symfony Cache library",
  "license": "MIT",
  "version": "0.3",
  "autoload": {
    "psr-4": {
      "CommonPHP\\Drivers\\Cache\\Symfony\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "CommonPHP\\Drivers\\Cache\\Symfony\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.5",
    "comphp/cache": "^0.3",
    "symfony/cache": "^8.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^13.1",
    "friendsofphp/php-cs-fixer": "^3.95"
  }
}